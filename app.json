{
  "expo": {
    "name": "Trilume",
    "slug": "mentalis-ai",
    "scheme": "trilume",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/trilume-icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.albert12k.trilume"
    },
    "android": {
      "package": "com.albert12k.trilume",
      "adaptiveIcon": {
        "backgroundColor": "#080810",
        "foregroundImage": "./assets/trilume-icon-adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/trilume-icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o Trilume acesse suas fotos para anexar anotações.",
          "cameraPermission": "Permitir que o Trilume use a câmera para registrar anotações."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Permitir que o Trilume grave áudios de aula.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C4DFF",
          "defaultChannel": "activity-reminders"
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      "expo-sqlite",
      "expo-status-bar",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/trilume-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#080810",
          "dark": {
            "image": "./assets/trilume-icon.png",
            "backgroundColor": "#080810"
          }
        }
      ],
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8b49c6e4-a7f6-48b7-bb8f-0f095722dd07"
      }
    },
    "owner": "albertkkk"
  }
}
